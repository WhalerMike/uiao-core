    "control-implementation": {
      "description": "Control implementations leveraged from UIAO components and compliance matrix",
      "set-parameters": [
        {
          "param-id": "PARAM-IAM-001",
          "values": [
            "Required for all privileged and non-privileged users"
          ],
          "remarks": "name: MFA Enforcement | method: Phishing-resistant (FIDO2 / PIV / CAC) | evidence_source: Microsoft Entra ID Conditional Access Policy"
        },
        {
          "param-id": "PARAM-IAM-002",
          "values": [
            "15 minutes"
          ],
          "remarks": "name: Session Timeout - Privileged | scope: CyberArk PSM / PTA sessions | evidence_source: CyberArk Vault Configuration Export"
        },
        {
          "param-id": "PARAM-IAM-003",
          "values": [
            "30 minutes"
          ],
          "remarks": "name: Session Timeout - Standard | scope: Entra ID token lifetime policy | evidence_source: Microsoft Entra ID Token Configuration"
        },
        {
          "param-id": "PARAM-IAM-004",
          "values": [
            "Minimum 16 characters, complexity enforced"
          ],
          "remarks": "name: Password Complexity | scope: All human accounts | evidence_source: Entra ID Authentication Methods Policy"
        },
        {
          "param-id": "PARAM-IAM-005",
          "values": [
            "5 consecutive failed attempts"
          ],
          "remarks": "name: Account Lockout Threshold | lockout_duration: 30 minutes or admin unlock | evidence_source: Entra ID Smart Lockout Configuration"
        },
        {
          "param-id": "PARAM-ADDR-001",
          "values": [
            "All endpoints registered in Infoblox DDI"
          ],
          "remarks": "name: IPAM Deterministic Assignment | scope: Enterprise network segments | evidence_source: Infoblox BloxOne DDI API"
        },
        {
          "param-id": "PARAM-ADDR-002",
          "values": [
            "All DNS queries logged with source IP and timestamp"
          ],
          "remarks": "name: DNS Resolution Logging | retention: 365 days minimum | evidence_source: Infoblox DNS Query Log Export"
        },
        {
          "param-id": "PARAM-OVL-001",
          "values": [
            "Required on all inter-segment traffic"
          ],
          "remarks": "name: mTLS Enforcement | scope: Cisco Catalyst SD-WAN fabric | evidence_source: Catalyst SD-WAN mTLS Policy Configuration"
        },
        {
          "param-id": "PARAM-OVL-002",
          "values": [
            "Micro-segmentation via SD-WAN policy with deny-by-default"
          ],
          "remarks": "name: Network Segmentation | scope: All VPN and branch connections | evidence_source: Cisco Catalyst SD-WAN Security Policy"
        },
        {
          "param-id": "PARAM-TEL-001",
          "values": [
            "365 days online, 3 years archived"
          ],
          "remarks": "name: Audit Log Retention | scope: All SIEM-ingested log sources | evidence_source: Microsoft Sentinel Retention Policy"
        },
        {
          "param-id": "PARAM-TEL-002",
          "values": [
            "Real-time for critical, 5-minute polling for standard"
          ],
          "remarks": "name: Continuous Monitoring Interval | scope: INR telemetry feed, Sentinel analytics rules | evidence_source: Microsoft INR Telemetry Configuration"
        },
        {
          "param-id": "PARAM-TEL-003",
          "values": [
            "Critical: 1 hour, High: 4 hours, Medium: 24 hours"
          ],
          "remarks": "name: Incident Response Time | scope: SOC triage workflow | evidence_source: Sentinel Automation Playbook SLA"
        },
        {
          "param-id": "PARAM-GOV-001",
          "values": [
            "Weekly automated scan against approved baseline"
          ],
          "remarks": "name: Configuration Baseline Scan | scope: All managed endpoints and servers | evidence_source: Microsoft Intune Compliance Policy"
        },
        {
          "param-id": "PARAM-GOV-002",
          "values": [
            "Authenticated scan every 72 hours"
          ],
          "remarks": "name: Vulnerability Scan Frequency | scope: All internet-facing and internal assets | evidence_source: Tenable / Defender Vulnerability Management"
        },
        {
          "param-id": "PARAM-GOV-003",
          "values": [
            "Monthly review cycle with 3PAO validation"
          ],
          "remarks": "name: Plan of Action & Milestones Review | scope: All open POA&M items | evidence_source: OSCAL POA&M Export"
        }
      ],
