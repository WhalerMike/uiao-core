# --- Modernization Atlas Config ---
# Copy this file to .env and fill in your agency values.
# NEVER commit the .env file to version control.

# Identity Plane (Entra ID)
TENANT_ID=your-agency-tenant-id
CLIENT_ID=atlas-app-registration-id
CLIENT_SECRET=your-secure-secret

# Management Plane (ServiceNow & InfoBlox)
SN_INSTANCE_NAME=agency-prod
SN_SVC_USER=atlas_service_acct
SN_SVC_PASS=password
INFOBLOX_URL=https://nios.agency.gov
INFOBLOX_USER=atlas_svc
INFOBLOX_PASS=password

# Management Plane (CyberArk)
CYBERARK_VAULT_URL=https://vault.agency.gov
CYBERARK_SVC_USER=atlas_cyberark_svc
CYBERARK_SVC_PASS=password

# Enforcement Plane (Network)
PANORAMA_URL=panorama.agency.gov
PANORAMA_API_KEY=your-api-key
VMANAGE_URL=https://vmanage.agency.gov
VMANAGE_USER=atlas_sdwan_svc
VMANAGE_PASS=password

# Visibility Plane (Sentinel)
LOG_ANALYTICS_WORKSPACE_ID=your-workspace-id

# Notifications (MS Teams)
TEAMS_WEBHOOK_URL=https://m365.webhook.office.com/...
