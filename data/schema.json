{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "uiao-core Appendix Canon Schema (v1.0-Phase1-Foundation)",
  "description": "Governs the Modernization Atlas data structure with FedRAMP 20x Phase 2 conditional requirements.",
  "type": "object",
  "properties": {
    "appendices": {
      "type": "object",
      "description": "Container for all appendix definitions (A-CZ).",
      "patternProperties": {
        "^[A-C][A-Z]?-[0-9]{2}$": {
          "type": "object",
          "required": [
            "title",
            "description",
            "status",
            "owner",
            "source_file",
            "config_snippet"
          ],
          "properties": {
            "title": { "type": "string" },
            "description": { "type": "string" },
            "status": { 
              "type": "string",
              "enum": ["Draft", "Review", "Approved"] 
            },
            "owner": { "type": "string" },
            "last_updated": { "type": "string", "format": "date" },
            "source_file": { "type": "string" },
            "config_snippet": { "type": "string" },
            "sgt_id": { 
              "type": "integer",
              "minimum": 2,
              "maximum": 65535,
              "description": "Required for Security (BA-) categories to map to the Identity Plane."
            }
          },
          "allOf": [
            {
              "if": {
                "propertyNames": { "pattern": "^BA-" }
              },
              "then": {
                "required": ["sgt_id"],
                "description": "Security appendices (BA-) must define an SGT ID for Zero-Trust enforcement."
              }
            }
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "required": ["appendices"]
}
