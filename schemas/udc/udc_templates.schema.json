{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://uiao.gov/schemas/udc/udc_templates.schema.json",
  "title": "UDC Templates Schema",
  "description": "JSON Schema for validating UDC template binding configurations",
  "type": "object",
  "required": ["template_id", "template_type", "template_file", "field_mappings"],
  "properties": {
    "template_id": {
      "type": "string",
      "description": "Unique template identifier"
    },
    "template_type": {
      "type": "string",
      "enum": ["docx", "pdf", "pptx", "xlsx", "md", "html"]
    },
    "template_file": {
      "type": "string",
      "description": "Path to template file relative to templates/"
    },
    "field_mappings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["variable", "source_field"],
        "properties": {
          "variable": { "type": "string" },
          "source_field": { "type": "string" },
          "transform": {
            "type": "string",
            "enum": ["none", "uppercase", "lowercase", "date_format", "markdown_to_html", "list_join"]
          }
        }
      }
    },
    "description": { "type": "string" },
    "applies_to": {
      "type": "array",
      "items": { "type": "string" }
    },
    "page_settings": {
      "type": "object",
      "properties": {
        "orientation": { "type": "string", "enum": ["portrait", "landscape"] },
        "margin_top": { "type": "string" },
        "margin_bottom": { "type": "string" },
        "margin_left": { "type": "string" },
        "margin_right": { "type": "string" }
      }
    },
    "header_footer": {
      "type": "object",
      "properties": {
        "header_text": { "type": "string" },
        "footer_text": { "type": "string" },
        "include_page_numbers": { "type": "boolean" }
      }
    }
  },
  "additionalProperties": true
}
