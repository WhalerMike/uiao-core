{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://uiao.gov/schemas/udc/udc_metadata.schema.json",
  "title": "UDC Metadata Schema",
  "description": "JSON Schema for validating UIAO canon artifact metadata",
  "type": "object",
  "required": ["id", "title", "version", "status", "authors", "canonical_path"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique document identifier",
      "pattern": "^UIAO-[A-Z]+-[0-9]{3}$"
    },
    "title": {
      "type": "string",
      "description": "Human-readable document title"
    },
    "version": {
      "type": "string",
      "description": "Semantic version",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "status": {
      "type": "string",
      "description": "Document lifecycle status",
      "enum": ["draft", "review", "approved", "published", "deprecated"]
    },
    "authors": {
      "type": "array",
      "description": "List of document authors",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "role": { "type": "string" },
          "organization": { "type": "string" }
        },
        "required": ["name"]
      }
    },
    "canonical_path": {
      "type": "string",
      "description": "Canonical file path within the repository"
    },
    "created_date": {
      "type": "string",
      "format": "date",
      "description": "ISO 8601 creation date"
    },
    "modified_date": {
      "type": "string",
      "format": "date",
      "description": "ISO 8601 last modified date"
    },
    "classification": {
      "type": "string",
      "enum": ["unclassified", "cui", "confidential"]
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "supersedes": {
      "type": "string",
      "description": "ID of document this version supersedes"
    },
    "sha256_hash": {
      "type": "string",
      "description": "SHA-256 hash for immutability verification"
    }
  },
  "additionalProperties": true
}
