{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://uiao.gov/schemas/udc/udc_pipeline.schema.json",
  "title": "UDC Pipeline Schema",
  "description": "JSON Schema for validating UDC compiler pipeline configurations",
  "type": "object",
  "required": ["pipeline_stages"],
  "properties": {
    "pipeline_stages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["stage", "name", "tool"],
        "properties": {
          "stage": { "type": "string" },
          "name": { "type": "string" },
          "tool": { "type": "string" },
          "description": { "type": "string" },
          "inputs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "outputs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "required": { "type": "boolean" },
          "supported_tools": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "pipeline_config": {
      "type": "object",
      "properties": {
        "fail_on_validation_error": { "type": "boolean" },
        "continue_on_warning": { "type": "boolean" },
        "parallel_compilation": { "type": "boolean" },
        "log_level": {
          "type": "string",
          "enum": ["debug", "info", "warning", "error"]
        }
      }
    }
  },
  "additionalProperties": true
}
