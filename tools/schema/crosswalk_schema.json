{
  "$comment": "<!-- NEW (Proposed) --> Crosswalk Schema",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UIAO Crosswalk Schema",
  "description": "Schema for validating compliance crosswalk entries.",
  "type": "object",
  "required": ["framework", "control_id", "mapping"],
  "properties": {
    "framework": {
      "type": "string",
      "enum": ["FedRAMP 20x", "NIST SP 800-53 Rev 5", "NIST SP 800-63", "TIC 3.0 Cloud", "TIC 3.0 Branch", "SCuBA"]
    },
    "control_id": {
      "type": "string",
      "minLength": 1
    },
    "mapping": {
      "type": "object",
      "properties": {
        "control_plane": { "type": "string" },
        "evidence_type": { "type": "string" },
        "canon_document": { "type": "string" }
      }
    }
  }
}
