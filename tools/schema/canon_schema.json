{
  "$comment": "<!-- NEW (Proposed) --> Canon Document Schema",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UIAO Canon Document Schema",
  "description": "Schema for validating canonical UIAO documents (00-11).",
  "type": "object",
  "required": ["document_number", "title", "version", "status"],
  "properties": {
    "document_number": {
      "type": "string",
      "pattern": "^(0[0-9]|1[0-1])$",
      "description": "Two-digit document number (00-11)."
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "status": {
      "type": "string",
      "enum": ["Draft", "Active", "Deprecated", "Archived"]
    },
    "control_planes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["Identity", "Network", "Addressing", "Telemetry", "Security", "Management"]
      }
    }
  }
}
