# .gitattributes — GitHub Linguist overrides
# Fixes language detection skewed by generated and vendored content.

# -----------------------------------------------------------------------------
# Generated paths: excluded from language stats and collapsed in diffs
# -----------------------------------------------------------------------------
docs/**                   linguist-generated=true
site/**                   linguist-generated=true
exports/**                linguist-generated=true
visuals/**                linguist-generated=true
assets/images/**          linguist-generated=true

# Generated file types (regardless of location)
*.html                    linguist-generated=true
*.pdf                     linguist-generated=true
*.docx                    linguist-generated=true

# -----------------------------------------------------------------------------
# Vendored paths: third-party or auto-managed content, excluded from stats
# -----------------------------------------------------------------------------
analytics/**              linguist-vendored=true
compliance/**             linguist-vendored=true
schemas/**                linguist-vendored=true

# -----------------------------------------------------------------------------
# Documentation: prose files, excluded from language stats
# -----------------------------------------------------------------------------
*.md                      linguist-documentation=true
canon/**                  linguist-documentation=true
data/**                   linguist-documentation=true

# -----------------------------------------------------------------------------
# Python source: ensure these directories are always detected as Python
# -----------------------------------------------------------------------------
src/uiao_core/**/*.py     linguist-detectable=true
scripts/**/*.py           linguist-detectable=true
tests/**/*.py             linguist-detectable=true
templates/**/*.py         linguist-detectable=true
